# Discord throwaway hesabın user token'i
# Tarayıcı devtools → Network → herhangi /api isteği → Headers → Authorization
DISCORD_TOKEN=your_discord_user_token_here

# Telegram bot token (BotFather'dan)
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLLmmNN

# Admin Telegram chat ID(ler)i — virgülle ayır
# Kendi chat ID'ni öğrenmek için @userinfobot'a mesaj at
ADMIN_CHAT_IDS=123456789

# Log seviyesi (trace/debug/info/warn/error)
LOG_LEVEL=info

# /lookup için dakika başına izin verilen sorgu sayısı
RATE_LIMIT_LOOKUP_PER_MIN=6

# Startup'ta sunucu member listelerini cache'le (tek seferlik gateway burst)
CHUNK_GUILDS_AT_STARTUP=true

# ─── RAM cache cap'leri (disk yazımı yok, restart'ta sıfırlanır) ──────────
# Kullanıcı x sunucu başına saklanacak mesaj sayısı (rolling)
MSG_CACHE_PER_USER_GUILD=500
# Toplam cache kapasitesi; aşılınca en eski kullanıcı temizlenir
MSG_CACHE_TOTAL=50000
# Kullanıcı x sunucu başına saklanacak voice oturum sayısı
VOICE_SESSIONS_PER_USER_GUILD=100
# Toplam voice oturum kapasitesi
VOICE_SESSIONS_TOTAL=10000

# ─── Search API (lookup sırasında her sunucu için 1-2 search call) ────────
# Discord'un kendi search özelliğinin altındaki API. UI'deki "search"
# kutusuyla aynı endpoint. History fetch DEĞİL — sadece bir kullanıcının
# o sunucudaki son ~25-200 mesajını çeker.
SEARCH_ON_LOOKUP=true
# Her sunucu için kaç sayfa çekilsin (1 sayfa = 25 mesaj, max 20 = 500 mesaj)
# Default 4 = sunucu başına 100 mesaj. Yüksek değer = uzun lookup + ban riski.
SEARCH_PAGES_PER_GUILD=4
# Sunucular arası gecikme (ms) — burst pattern olmasın diye
SEARCH_DELAY_BETWEEN_GUILDS_MS=1500
# Aynı sunucuda sayfalar arası gecikme (ms)
SEARCH_DELAY_BETWEEN_PAGES_MS=500
# Tek lookup'ta search yapılacak maksimum sunucu sayısı
# Bu cap'i aşan sunucular search'siz, sadece live cache ile raporlanır
SEARCH_MAX_GUILDS=50

# Çalışma ortamı (production'da DiskWriteGuard aktif olur)
NODE_ENV=production
